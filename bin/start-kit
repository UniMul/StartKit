#!/usr/bin/env bash
set -euo pipefail

START_KIT_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

source "${START_KIT_ROOT}/lib/log.sh"
source "${START_KIT_ROOT}/lib/common.sh"
source "${START_KIT_ROOT}/lib/resolver.sh"
source "${START_KIT_ROOT}/lib/scaffold.sh"
source "${START_KIT_ROOT}/lib/init.sh"
source "${START_KIT_ROOT}/lib/help.sh"

show_version() {
  if [[ -f "${START_KIT_ROOT}/VERSION" ]]; then
    echo "start-kit v$(cat "${START_KIT_ROOT}/VERSION")"
  else
    echo "start-kit vunknown"
  fi
}

parse_new_flags() {
  NEW_CUSTOM_ROOT="default"

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --custom)
        shift
        [[ $# -gt 0 ]] || fail "--custom requires a value"
        NEW_CUSTOM_ROOT="$1"
        shift
        ;;
      *)
        fail "unknown option: $1"
        ;;
    esac
  done
}

case "${1:-help}" in
  init)
    init_custom_layout
    ;;
  version|--version|-v)
    show_version
    ;;
  help|-h|--help)
    show_help
    ;;
  new)
    case "${2:-}" in
      module)
        name="${3:?module name required}"
        shift 3
        parse_new_flags "$@"
        new_module "$name" "$NEW_CUSTOM_ROOT"
        ;;
      profile)
        name="${3:?profile name required}"
        shift 3
        parse_new_flags "$@"
        new_profile "$name" "$NEW_CUSTOM_ROOT"
        ;;
      *)
        show_help
        exit 1
        ;;
    esac
    ;;
  *)
    show_help
    exit 1
    ;;
esac
